---
import Layout from '../../layouts/Layout.astro';
import Emblem from '../../components/Emblem.astro';
import { places, placeBySlug, characterBySlug, eventBySlug } from '../../lib/lookups';

export function getStaticPaths() {
  return places.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const p = placeBySlug.get(slug!)!;

const ZONE_LABEL = { house: 'The Buendía house', town: 'Macondo', beyond: 'Beyond the swamp' };
---

<Layout title={p.name} description={p.tagline}>
  <article>
    <header class="page-head with-emblem">
      <div>
        <p class="eyebrow">{ZONE_LABEL[p.zone]}</p>
        <h1>{p.name}</h1>
        <p class="lede">{p.tagline}</p>
      </div>
      <Emblem kind="places" slug={p.slug} class="head-emblem" />
    </header>

    <div class="dossier">
      <div class="prose">
        {p.summary.map((para) => <p>{para}</p>)}
      </div>

      <aside>
        {
          p.residents.length > 0 && (
            <div class="aside-block">
              <p class="eyebrow">Bound to this place</p>
              <ul>
                {p.residents.map((r) => {
                  const c = characterBySlug.get(r.character);
                  return c ? (
                    <li class={`bl-${c.bloodline}`}>
                      <a href={`/characters/${c.slug}`}>{c.name}</a>
                      <span class="why">{r.bond}</span>
                    </li>
                  ) : null;
                })}
              </ul>
            </div>
          )
        }

        {
          p.events.length > 0 && (
            <div class="aside-block">
              <p class="eyebrow">What happened here</p>
              <ul>
                {p.events.map((slug) => {
                  const e = eventBySlug.get(slug);
                  return e ? (
                    <li>
                      <a href={`/timeline#${e.slug}`}>{e.title}</a>
                    </li>
                  ) : null;
                })}
              </ul>
            </div>
          )
        }

        {
          p.map && (
            <div class="aside-block">
              <p class="eyebrow">On the map</p>
              <ul>
                <li>
                  <a href="/map">See it in the town plan →</a>
                </li>
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </article>
</Layout>

<style>
  .with-emblem {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    max-width: var(--max-wide);
  }

  .head-emblem {
    width: clamp(9rem, 18vw, 14rem);
    flex: none;
  }

  @media (max-width: 640px) {
    .with-emblem {
      flex-direction: column-reverse;
    }
  }

  .dossier aside {
    border-top-color: var(--ink);
  }

  .aside-block li a {
    color: var(--bl, var(--ink));
  }
</style>
