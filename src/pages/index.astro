---
import Layout from '../layouts/Layout.astro';
import ButterflyHero from '../components/ButterflyHero.astro';
import FamilyTree from '../components/FamilyTree.astro';
import { characters, places, events, relations, motifs } from '../lib/lookups';
---

<Layout
  title="The Buendía Family Tree"
  description="An interactive atlas of One Hundred Years of Solitude — seven generations of Buendías, the town of Macondo, and the web that binds them."
>
  <ButterflyHero />

  <section id="tree" class="tree-section">
    <p class="eyebrow">The hub of the atlas</p>
    <h2>The Buendía family tree</h2>
    <p class="tree-lede">
      Hover a name to light up its bloodline; click through to any life. The red arcs are
      the line folding into itself.
    </p>
    <FamilyTree />
  </section>

  <section class="counts" aria-label="What the atlas holds">
    <a href="/characters"><strong>{characters.length}</strong> characters</a>
    <a href="/places"><strong>{places.length}</strong> places</a>
    <a href="/timeline"><strong>{events.length}</strong> events</a>
    <a href="/web"><strong>{relations.length}</strong> bonds</a>
    <a href="/motifs"><strong>{motifs.length}</strong> motifs</a>
  </section>
</Layout>

<style>
  .tree-section {
    scroll-margin-top: 1.5rem;
    max-width: var(--max-wide);
  }

  .tree-section h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    margin: 0.5rem 0 0.6rem;
  }

  .tree-lede {
    color: var(--ink-soft);
    max-width: var(--max-prose);
    margin-bottom: 1.8rem;
  }

  .counts {
    display: flex;
    flex-wrap: wrap;
    gap: 2.2rem;
    margin-top: 3.5rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--hairline);
    max-width: var(--max-wide);
  }

  .counts a {
    font-family: var(--f-label);
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
  }

  .counts a:hover {
    background: var(--butterfly-soft);
  }

  .counts strong {
    font-family: var(--f-display);
    font-size: 1.6rem;
    font-weight: 620;
    color: var(--ink);
    margin-right: 0.35em;
  }
</style>
